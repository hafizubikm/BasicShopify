[
  {
    "name": "theme_info",
    "theme_name": "Sportify",
    "theme_version": "1.0.0",
    "theme_author": "Sportify Themes",
    "theme_documentation_url": "https://example.com",
    "theme_support_url": "https://example.com/support"
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 240,
        "step": 10,
        "default": 140,
        "unit": "px",
        "label": "Logo width"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#ff5a1f"
      },
      {
        "type": "color",
        "id": "color_dark",
        "label": "Dark surface",
        "default": "#0a0a0a"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted surface",
        "default": "#f4f4f4"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "type_body",
        "label": "Body font family",
        "default": "system",
        "options": [
          { "value": "system", "label": "System Sans" },
          { "value": "serif", "label": "Serif" }
        ]
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_twitter", "label": "Twitter URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" }
    ]
  }
]
