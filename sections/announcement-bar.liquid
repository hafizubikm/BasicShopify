<div class="announcement-bar">
  <div class="container">
    <p>{{ section.settings.message }}</p>
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Free shipping on orders over $75"
    }
  ]
}
{% endschema %}
