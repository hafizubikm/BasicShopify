<section class="hero" {% if section.settings.image != blank %}style="background-image: url('{{ section.settings.image | image_url: width: 2000 }}')"{% endif %}>
  <div class="hero__overlay"></div>
  <div class="container hero__inner hero__inner--{{ section.settings.alignment }}">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.subtext != blank -%}
      <p class="hero__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--large">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "NEW ARRIVALS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Train harder. Run faster." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Premium gear engineered for athletes who never settle." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
