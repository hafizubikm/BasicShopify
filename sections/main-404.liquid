<section class="error-404">
  <div class="container container--narrow text-center">
    <p class="error-404__code">404</p>
    <h1 class="error-404__title">{{ 'general.404.title' | t }}</h1>
    <p class="error-404__text">{{ 'general.404.subtext' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn btn--primary">{{ 'general.404.link' | t }}</a>
  </div>
</section>

{% schema %}
{ "name": "404", "settings": [] }
{% endschema %}
