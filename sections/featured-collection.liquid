<section class="section featured-collection">
  <div class="container">
    <header class="section__header">
      <h2 class="section__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.collection != blank -%}
        <a href="{{ collections[section.settings.collection].url }}" class="section__link">View all →</a>
      {%- endif -%}
    </header>

    <div class="product-grid">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products limit: section.settings.product_count -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.product_count) -%}
          <div class="product-card product-card--placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
            <div class="product-card__body">
              <h3 class="product-card__title">Sample product</h3>
              <p class="product-card__price">$0.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to show",
      "min": 2, "max": 12, "step": 1, "default": 4
    }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
