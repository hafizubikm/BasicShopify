<section class="blog">
  <div class="container">
    <h1 class="blog__title">{{ blog.title }}</h1>
    {%- paginate blog.articles by 12 -%}
      <div class="blog__grid">
        {%- for article in blog.articles -%}
          <article class="article-card">
            {%- if article.image -%}
              <a href="{{ article.url }}" class="article-card__media">
                {{ article.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: article.title }}
              </a>
            {%- endif -%}
            <div class="article-card__body">
              <p class="article-card__meta">{{ article.published_at | date: '%b %d, %Y' }}</p>
              <h2 class="article-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
              <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 24 }}</p>
              <a href="{{ article.url }}" class="article-card__link">{{ 'blogs.article.read_more' | t }} →</a>
            </div>
          </article>
        {%- endfor -%}
      </div>
      {% render 'pagination', paginate: paginate %}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
