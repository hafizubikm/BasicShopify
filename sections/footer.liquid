<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <a href="{{ routes.root_url }}" class="site-footer__logo">{{ shop.name }}</a>
      {%- if section.settings.tagline != blank -%}
        <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    <div class="site-footer__columns">
      {%- for block in section.blocks -%}
        <div class="site-footer__column" {{ block.shopify_attributes }}>
          <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
          {%- if block.settings.menu != blank -%}
            <ul class="site-footer__list">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="site-footer__social">
      {%- if settings.social_instagram != blank -%}
        <a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>
      {%- endif -%}
      {%- if settings.social_facebook != blank -%}
        <a href="{{ settings.social_facebook }}" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>
      {%- endif -%}
      {%- if settings.social_twitter != blank -%}
        <a href="{{ settings.social_twitter }}" aria-label="Twitter">{% render 'icon', name: 'twitter' %}</a>
      {%- endif -%}
      {%- if settings.social_youtube != blank -%}
        <a href="{{ settings.social_youtube }}" aria-label="YouTube">{% render 'icon', name: 'youtube' %}</a>
      {%- endif -%}
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container">
      <small>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ powered_by_link }}</small>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Gear for athletes who refuse to slow down."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "menu_column", "settings": { "heading": "Shop" } },
      { "type": "menu_column", "settings": { "heading": "Help" } },
      { "type": "menu_column", "settings": { "heading": "Company" } }
    ]
  }
}
{% endschema %}
